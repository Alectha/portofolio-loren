# Example environment variables for production
# Copy this file to `.env.local` for local development (do NOT commit secrets).

# Example public base URL (optional)
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Analytics or other public keys (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# If you use any private keys in the project, set them in Vercel as Secrets
# e.g. VERCEL_TOKEN is required for the GitHub Action to deploy (set in GitHub repo secrets),
# but should NOT be stored in this repo.
